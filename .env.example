GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=
# Required for chat — get key from your LLM provider or /agentbase-llm (GreenNode AIP)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=
LLM_MODEL=
# Secret token configured in Zalo webhook settings. Used to authorize inbound webhook calls.
ZALO_WEBHOOK_SECRET_TOKEN=
# Zalo Bot Platform token used to call /sendMessage
ZALO_BOT_TOKEN=
# Path to transfer CSV (default: data/transfers.csv)
TRANSFERS_CSV_PATH=data/transfers.csv
# Optional: cap rows for dev (e.g. 100000). Leave empty for all rows.
MAX_ROWS=
